{
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "auto-close-tag.SublimeText3Mode": true,
  "breadcrumbs.filePath": "off",
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.accessibilitySupport": "off",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.fontFamily": "DankMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontWeight": "600",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": false,
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "trailing",
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.wordWrapColumn": 120,
  "emmet.triggerExpansionOnTab": true,
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableCommitSigning": true,
  "git.enableSmartCommit": true,
  "git.ignoreRebaseWarning": true,
  "githubPullRequests.pullBranch": "never",
  "gitlens.blame.compact": false,
  "javascript.updateImportsOnFileMove.enabled": "never",
  "javascript.validate.enable": false,
  "material-icon-theme.activeIconPack": "react_redux",
  "redhat.telemetry.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.external.osxExec": "",
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1",
    "Q_NEW_SESSION": "1"
  },
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.tabs.enabled": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.colorTheme": "Draculinho",
  "workbench.editor.tabSizing": "shrink",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.panel.defaultLocation": "right",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.statusBar.visible": true,
  "editor.stickyScroll.enabled": false,
  "vue.server.hybridMode": false,
  "i18n-ally.displayLanguage": "pt-BR",
  "workbench.editor.enablePreview": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "geminicodeassist.project": "eduardoborges-d0f17",
  "geminicodeassist.inlineSuggestions.enableAuto": true,
  "workbench.activityBar.compact": true,
  "workbench.activityBar.location": "top",
  "claudeCode.preferredLocation": "panel",
  "chat.viewSessions.orientation": "stacked",
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.eagerness": "high",
  "editor.fontSize": 13,
  "window.commandCenter": false,
  "chat.titleBar.openInAgentsWindow.enabled": false,
  "workbench.browser.showInTitleBar": true,
  "editor.linkedEditing": true,
  "editor.smoothScrolling": false,
  "workbench.list.smoothScrolling": false,
  "terminal.integrated.smoothScrolling": false,
  "[vue]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  }
}